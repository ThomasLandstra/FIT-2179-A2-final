{
	"$schema": "https://vega.github.io/schema/vega-lite/v6.json",
	"description": "Dashboard showing support for a 25% flat gas export tax overall and broken down by chosen groups.",
	"data": {
		"url": "data/gas_tax/consolidated_gas_tax_support.csv"
	},
	"params": [
		{
			"name": "SelectGroup",
			"value": "age+sex"
		}
	],
	"vconcat": [
		{
			"title": {
				"text": "Overall Support for 25% Gas Export Tax",
				"anchor": "start",
				"fontSize": 20,
				"offset": 10
			},
			"transform": [
				{ "filter": "datum.Group == 'overall'" },
				{
					"calculate": "datum.Response == 'Strongly agree' ? 1 : datum.Response == 'Agree' ? 2 : datum.Response == 'Disagree' ? 3 : datum.Response == 'Strongly disagree' ? 4 : 5",
					"as": "resp_order"
				},
				{ "sort": [{ "field": "resp_order", "order": "ascending" }] }
			],
			"width": "container",
			"autosize": {
				"type": "fit",
				"contains": "padding"
			},
			"height": 200,
			"mark": {
				"type": "arc",
				"innerRadius": 70,
				"outerRadius": 120,
				"stroke": "#fff",
				"strokeWidth": 1
			},
			"encoding": {
				"theta": { "field": "Value", "type": "quantitative" },
				"color": {
					"field": "Response",
					"type": "nominal",
					"scale": {
						"domain": [
							"Strongly agree",
							"Agree",
							"Disagree",
							"Strongly disagree",
							"Don't know / Not sure"
						],
						"range": ["#2e7d32", "#81c784", "#e57373", "#c62828", "#b0bec5"]
					},
					"legend": {
						"title": "Response Category",
						"orient": "none",
						"legendX": 700,
						"legendY": 25,
						"labelFontSize": 16,
						"titleFontSize": 18
					}
				},
				"order": {
					"field": "resp_order",
					"type": "quantitative",
					"sort": "ascending"
				},
				"tooltip": [
					{ "field": "Response", "type": "nominal", "title": "Response" },
					{
						"field": "Value",
						"type": "quantitative",
						"title": "Percentage",
						"format": ".0%"
					}
				]
			}
		},
		{
			"transform": [{ "filter": "datum.Group == SelectGroup" }],
			"facet": {
				"field": "Category",
				"type": "nominal",
				"sort": { "field": "Sort_Order", "order": "ascending" },
				"header": {
					"title": null,
					"labelFontSize": 16,
					"labelFontWeight": "bold",
					"labelPadding": 8
				}
			},
			"columns": 3,
			"spec": {
				"transform": [
					{
						"calculate": "datum.Response == 'Strongly agree' ? 1 : datum.Response == 'Agree' ? 2 : datum.Response == 'Disagree' ? 3 : datum.Response == 'Strongly disagree' ? 4 : 5",
						"as": "resp_order"
					},
					{ "sort": [{ "field": "resp_order", "order": "ascending" }] }
				],
				"width": 330,
				"height": 280,
				"mark": {
					"type": "arc",
					"innerRadius": 70,
					"outerRadius": 120,
					"stroke": "#fff",
					"strokeWidth": 1
				},
				"encoding": {
					"theta": { "field": "Value", "type": "quantitative" },
					"color": {
						"field": "Response",
						"type": "nominal",
						"scale": {
							"domain": [
								"Strongly agree",
								"Agree",
								"Disagree",
								"Strongly disagree",
								"Don't know / Not sure"
							],
							"range": ["#2e7d32", "#81c784", "#e57373", "#c62828", "#b0bec5"]
						},
						"legend": null
					},
					"order": {
						"field": "resp_order",
						"type": "quantitative",
						"sort": "ascending"
					},
					"tooltip": [
						{ "field": "Category", "type": "nominal", "title": "Group" },
						{ "field": "Response", "type": "nominal", "title": "Response" },
						{
							"field": "Value",
							"type": "quantitative",
							"title": "Percentage",
							"format": ".0%"
						}
					]
				}
			}
		}
	],
	"config": {
		"background": "#ffffff",
		"title": {
			"font": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"fontSize": 16,
			"fontWeight": "600",
			"anchor": "start",
			"color": "#0f172a"
		},
		"view": { "stroke": "transparent" },
		"axis": {
			"labelFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"labelFontSize": 12,
			"titleFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"titleFontSize": 13,
			"grid": false,
			"domainColor": "#e6eef8",
			"tickColor": "#cfe0f5"
		},
		"legend": {
			"labelFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"labelFontSize": 16,
			"titleFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"titleFontSize": 17
		},
		"range": {
			"category": [
				"#08306b",
				"#2166ac",
				"#2b8cbe",
				"#67a9cf",
				"#b3cde3",
				"#c7e9fb",
				"#4fb3bf",
				"#74add1"
			]
		},
		"mark": { "color": "#2b6cb0" }
	}
}
