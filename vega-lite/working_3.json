{
	"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
	"width": "container",
	"height": 500,
	"params": [
		{
			"name": "zoom",
			"value": 130,
			"bind": {
				"input": "range",
				"min": 130,
				"max": 1500,
				"step": 10,
				"name": "Zoom Level"
			}
		},
		{
			"name": "pan_lon",
			"value": 0,
			"bind": {
				"input": "range",
				"min": -180,
				"max": 180,
				"step": 2,
				"name": "Pan Horizontally (Longitude)"
			}
		},
		{
			"name": "pan_lat",
			"value": 0,
			"bind": {
				"input": "range",
				"min": -90,
				"max": 90,
				"step": 2,
				"name": "Pan Vertically (Latitude)"
			}
		}
	],
	"projection": {
		"type": "equalEarth",
		"rotate": [-130, 0, 0],
		"scale": {
			"expr": "zoom"
		},
		"center": {
			"expr": "[pan_lon, pan_lat]"
		}
	},
	"layer": [
		{
			"data": {
				"url": "data/ne_10m_world_countries.json",
				"format": {
					"type": "topojson",
					"feature": "ne_10m_admin_0_countries"
				}
			},
			"mark": {
				"type": "geoshape",
				"stroke": "white",
				"fill": "lightgray"
			}
		},
		{
			"data": {
				"url": "data/oil_imports_by_country.csv"
			},
			"transform": [
				{
					"filter": "datum.Oil_Imports >= 200"
				},
				{
					"lookup": "Country",
					"from": {
						"data": {
							"url": "data/nation_centroids.csv"
						},
						"key": "COUNTRY",
						"fields": ["longitude", "latitude"]
					},
					"as": ["origin_lon", "origin_lat"]
				},
				{
					"calculate": "'Australia'",
					"as": "dest_name"
				},
				{
					"lookup": "dest_name",
					"from": {
						"data": {
							"url": "data/nation_centroids.csv"
						},
						"key": "COUNTRY",
						"fields": ["longitude", "latitude"]
					},
					"as": ["dest_lon", "dest_lat"]
				},
				{
					"calculate": "{'type': 'Feature', 'geometry': {'type': 'LineString', 'coordinates': [[datum.origin_lon, datum.origin_lat], [datum.dest_lon, datum.dest_lat]]}}",
					"as": "route"
				}
			],
			"mark": {
				"type": "geoshape",
				"filled": false,
				"strokeOpacity": 0.6,
				"color": "firebrick"
			},
			"encoding": {
				"shape": {
					"field": "route",
					"type": "geojson"
				},
				"strokeWidth": {
					"field": "Oil_Imports",
					"type": "quantitative",
					"scale": {
						"range": [1.5, 8]
					},
					"title": "Oil Import Volume"
				},
				"tooltip": [
					{ "field": "Country", "type": "nominal" },
					{ "field": "Oil_Imports", "type": "quantitative" }
				]
			}
		}
	],
	"config": {
		"background": "#ffffff",
		"title": {
			"font": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"fontSize": 16,
			"fontWeight": "600",
			"anchor": "start",
			"color": "#0f172a"
		},
		"view": { "stroke": "transparent" },
		"axis": {
			"labelFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"labelFontSize": 12,
			"titleFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"titleFontSize": 13,
			"grid": false,
			"domainColor": "#e6eef8",
			"tickColor": "#cfe0f5"
		},
		"legend": {
			"labelFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"labelFontSize": 12,
			"titleFont": "Inter, 'Helvetica Neue', Arial, sans-serif",
			"titleFontSize": 13
		},
		"range": {
			"category": [
				"#08306b",
				"#2166ac",
				"#2b8cbe",
				"#67a9cf",
				"#b3cde3",
				"#c7e9fb",
				"#4fb3bf",
				"#74add1"
			]
		},
		"mark": { "color": "#2b6cb0" }
	}
}
